{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "priscillapetty-website",
  "compatibility_date": "2026-07-09",
  "pages_build_output_dir": ".",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "r2_buckets": [
    {
      "binding": "VIDEOS",
      "bucket_name": "priscillapetty-videos"
    }
  ]
}
